# Riferimento delle variabili d'ambiente del progetto.
#
# IMPORTANTE — modalità di lavoro: tutto in cloud (Claude Code on the web,
# GitHub, Vercel, Supabase). Le credenziali NON si tengono in file .env locali:
# si impostano nei pannelli dei rispettivi servizi:
#
#   - Vercel  → Project Settings → Environment Variables
#               (NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY,
#                SUPABASE_SERVICE_ROLE_KEY, NEXT_PUBLIC_TENANT_ID)
#   - Supabase → Project Settings → Auth/API
#               (lì leggi i valori da copiare in Vercel; il service role NON
#                deve mai uscire dal lato server)
#   - Claude Code on the web → Environment → Environment Variables
#               (per esecuzioni una tantum come `npm run bootstrap`)
#
# Questo file resta a titolo di documentazione del set richiesto.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mai esporre al browser: usata solo da route server e dallo script bootstrap.
SUPABASE_SERVICE_ROLE_KEY=

# In Fase 1 c'è un solo tenant. L'ID è usato lato client per i lookup di stream.
NEXT_PUBLIC_TENANT_ID=00000000-0000-0000-0000-000000000001
